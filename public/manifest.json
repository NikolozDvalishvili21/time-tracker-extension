{
  "manifest_version": 3,
  "name": "Time Tracker",
  "version": "1.0.0",
  "description": "Track time spent on specific tabs",
  "permissions": ["tabs", "storage", "activeTab", "alarms"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Time Tracker"
  },
  "background": {
    "service_worker": "background.js"
  }
}
